<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <!-- Yellow background with rounded corners -->
  <rect width="512" height="512" rx="100" ry="100" fill="#F5D800"/>
  
  <!-- Green accent bar at bottom like Ledermair logo -->
  <rect x="40" y="460" width="432" height="12" rx="6" fill="#CC0000" opacity="0.7"/>
  
  <!-- BUS text - top half -->
  <text x="256" y="220"
    font-family="Arial Black, sans-serif"
    font-size="190"
    font-weight="900"
    fill="#1A5C2A"
    text-anchor="middle"
    dominant-baseline="middle"
    letter-spacing="-8">BUS</text>
  
  <!-- CHECK text - bottom half -->
  <text x="256" y="370"
    font-family="Arial Black, sans-serif"
    font-size="130"
    font-weight="900"
    fill="#1A5C2A"
    text-anchor="middle"
    dominant-baseline="middle"
    letter-spacing="-4">CHECK</text>
</svg>